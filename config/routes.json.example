# routes.json is shared by cmd/broker (HTTP proxy) and cmd/feedserver (TCP feed).
# Both resolve tenant_key → upstream credentials via broker.Registry.
# Replace *_REPLACE values with real credentials before running in production.
{
  "routes": [
    {
      "tenant_id": "default",
      "tenant_key": "test-key",
      "upstream_base": "https://api.example-partner.com",
      "upstream_key": "sk_partner_REPLACE",
      "allowed_paths": [],
      "strip_headers": [],
      "inject_headers": {},
      "max_body_bytes": 0,
      "enabled": true
    },
    {
      "tenant_id": "acme-corp",
      "tenant_key": "tk_acme_REPLACE",
      "upstream_base": "https://api.example-partner.com",
      "upstream_key": "sk_partner_REPLACE",
      "allowed_paths": ["/v1/"],
      "strip_headers": ["X-Internal-Debug"],
      "inject_headers": {"X-Broker-Version": "1"},
      "max_body_bytes": 0,
      "enabled": true
    }
  ]
}
